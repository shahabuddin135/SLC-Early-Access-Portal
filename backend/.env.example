DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
SECRET_KEY=your-secret-key-change-this-in-production
DOWNLOAD_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
# FRONTEND_URL is optional in production. Leave empty to use X-App-Base-Url header
# Set only if header mechanism isn't available or needs a fallback.
# In development: defaults to http://localhost:3000 if empty
FRONTEND_URL=
# Optional extra hostnames allowed in emailed links, besides X-App-Base-Url host,
# *.vercel.app and localhost (comma-separated). Usually leave blank.
ALLOWED_REDIRECT_HOSTS=
ENVIRONMENT=development
RESEND_API_KEY=

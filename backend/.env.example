DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
SECRET_KEY=your-secret-key-change-this-in-production
DOWNLOAD_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
# Canonical site URL used to build emailed links (verify, reset, dashboard, docs)
# when the per-request X-App-Base-Url header is absent. The header still takes
# priority, so preview/custom domains adapt automatically. Set this to your
# production domain — if left blank, deployed emails can fall back to localhost.
FRONTEND_URL=https://slc-early-access-portal.vercel.app
# Optional extra hostnames allowed in emailed links, besides X-App-Base-Url host,
# *.vercel.app and localhost (comma-separated). Usually leave blank.
ALLOWED_REDIRECT_HOSTS=
ENVIRONMENT=development
RESEND_API_KEY=
